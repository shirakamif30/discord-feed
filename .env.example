# Discord Feed Bot - Environment Variables
# Copy this to .env and fill in your values

# Discord Bot Token (REQUIRED - get from https://discord.com/developers)
# NOTE: If your host locks .env token, use config.json instead
DISCORD_TOKEN=your_bot_token_here

# Polling interval in minutes (default: 5)
POLL_INTERVAL=5

# Max embed description length (default: 300)
MAX_DESCRIPTION_LENGTH=300

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Enable HD media (true/false, default: true)
HD_MEDIA=true
